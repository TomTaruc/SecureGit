# Flask
SECRET_KEY=generate-64-char-random-hex-here
JWT_SECRET_KEY=generate-64-char-random-hex-here
FLASK_ENV=development

# Database
# Development (SQLite — no PostgreSQL needed locally):
# DATABASE_URL=sqlite:///securegit_dev.db
# Production (PostgreSQL):
DATABASE_URL=postgresql://securegit_app:CHANGE_ME@localhost:5432/securegit_db

# Git
GIT_REPOS_BASE=/srv/git
GIT_USER=git
AUTHORIZED_KEYS_PATH=/home/git/.ssh/authorized_keys
GITEA_HOOK=/usr/share/gitea/contrib/gitea-git-hook

# Internal hook secret (must match post-receive.sh)
INTERNAL_HOOK_SECRET=generate-32-char-random-hex-here

# DNS
INTERNAL_DOMAIN=securegit.local

# Backup
BACKUP_DEST_PATH=/mnt/backup
